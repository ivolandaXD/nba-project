<div class="max-w-md mx-auto">
  <h1 class="text-2xl font-bold text-slate-800 mb-6">Entrar</h1>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: 'space-y-4' }) do |f| %>
    <div>
      <%= f.label :email, class: 'block text-sm font-medium text-slate-700 mb-1' %>
      <%= f.email_field :email, autofocus: true, autocomplete: 'email', class: 'w-full rounded border border-slate-300 px-3 py-2 text-sm' %>
    </div>
    <div>
      <%= f.label :password, 'Senha', class: 'block text-sm font-medium text-slate-700 mb-1' %>
      <%= f.password_field :password, autocomplete: 'current-password', class: 'w-full rounded border border-slate-300 px-3 py-2 text-sm' %>
    </div>
    <div class="flex items-center gap-2">
      <%= f.check_box :remember_me, class: 'rounded border-slate-300' %>
      <%= f.label :remember_me, 'Lembrar-me', class: 'text-sm text-slate-600' %>
    </div>
    <%= f.submit 'Entrar', class: 'w-full bg-orange-600 hover:bg-orange-700 text-white font-medium py-2 px-4 rounded cursor-pointer' %>
  <% end %>
</div>
