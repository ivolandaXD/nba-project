<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title>NBA Lab (interno)</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-slate-50 text-slate-900 min-h-screen">
    <header class="bg-slate-900 text-white shadow">
      <div class="max-w-6xl mx-auto px-4 py-3 flex flex-wrap items-center justify-between gap-3">
        <div class="flex items-center gap-4">
          <%= link_to 'NBA Lab', root_path, class: 'font-semibold text-lg tracking-tight' %>
          <% if user_signed_in? %>
            <%= link_to 'Jogos (hoje)', root_path, class: 'text-sm text-slate-300 hover:text-white' %>
            <%= link_to 'Ranking', ranking_path, class: 'text-sm text-slate-300 hover:text-white' %>
          <% end %>
        </div>
        <% if user_signed_in? %>
          <div class="flex items-center gap-3 text-sm">
            <span class="text-slate-400"><%= current_user.email %></span>
            <% if current_user.admin? %>
              <span class="rounded bg-amber-500/20 text-amber-200 px-2 py-0.5 text-xs font-medium">admin</span>
            <% end %>
            <%= button_to 'Sair', destroy_user_session_path, method: :delete, class: 'bg-slate-700 hover:bg-slate-600 rounded px-3 py-1 text-xs' %>
          </div>
        <% end %>
      </div>
    </header>

    <% if notice.present? %>
      <div class="max-w-6xl mx-auto px-4 pt-4">
        <p class="rounded-lg bg-emerald-100 text-emerald-900 px-4 py-2 text-sm"><%= notice %></p>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="max-w-6xl mx-auto px-4 pt-4">
        <p class="rounded-lg bg-red-100 text-red-900 px-4 py-2 text-sm"><%= alert %></p>
      </div>
    <% end %>

    <main class="max-w-6xl mx-auto px-4 py-8">
      <%= yield %>
    </main>
  </body>
</html>
