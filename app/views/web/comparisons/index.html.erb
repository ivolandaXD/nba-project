<h1 class="text-2xl font-bold text-slate-800 mb-2">Comparar</h1>
<p class="text-slate-600 text-sm mb-6">Análises por time e confrontos de jogador vs adversário.</p>

<div class="grid gap-4 md:grid-cols-2">
  <%= link_to comparisons_teams_path, class: 'block rounded-xl border border-slate-200 bg-white p-4 shadow-sm hover:border-orange-300 transition' do %>
    <h2 class="text-lg font-semibold text-slate-900">Times</h2>
    <p class="text-sm text-slate-600 mt-2">Elencos com stats de temporada importadas e jogos entre dois times no banco.</p>
  <% end %>
  <%= link_to comparisons_matchup_path, class: 'block rounded-xl border border-slate-200 bg-white p-4 shadow-sm hover:border-orange-300 transition' do %>
    <h2 class="text-lg font-semibold text-slate-900">Jogador × adversário</h2>
    <p class="text-sm text-slate-600 mt-2">Médias do jogador contra um time (game logs) e jogos do time do jogador contra esse adversário.</p>
  <% end %>
</div>
