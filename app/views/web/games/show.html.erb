<div class="mb-4">
  <%= link_to '← Voltar aos jogos do dia', root_path, class: 'text-sm text-orange-700 hover:underline' %>
</div>

<div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm mb-4">
  <h1 class="text-2xl font-bold text-slate-900">
    <span class="text-orange-700"><%= @game.away_team %></span>
    <span class="text-slate-400 mx-2">@</span>
    <span><%= @game.home_team %></span>
  </h1>
  <p class="text-slate-600 mt-2">
    <%= @game.game_date&.strftime('%d/%m/%Y') %>
    <% if @game.status.present? %>
      <span class="text-slate-400"> · </span><%= @game.status %>
    <% end %>
  </p>

  <% if current_user.admin? %>
    <div class="mt-4 flex flex-wrap gap-2">
      <%= button_to 'Importar game logs', import_game_logs_game_path(@game), method: :post,
          class: 'bg-slate-800 hover:bg-slate-700 text-white text-sm py-2 px-3 rounded',
          data: { confirm: 'Importar logs da NBA para todos os jogadores deste jogo com nba_player_id?' } %>
      <%= button_to 'Atualizar odds', fetch_odds_game_path(@game), method: :post,
          class: 'bg-indigo-700 hover:bg-indigo-600 text-white text-sm py-2 px-3 rounded' %>
    </div>
  <% end %>
</div>

<h2 class="text-lg font-semibold text-slate-800 mb-2">Temporada · resumo por time</h2>
<p class="text-xs text-slate-500 mb-3">Médias por jogo e recorde (<code class="bg-slate-100 px-0.5 rounded">team_season_stats</code>), temporada <strong><%= @season %></strong>. Abreviações: visitante <code class="bg-slate-100 px-0.5 rounded"><%= @away_abbr || '—' %></code> · casa <code class="bg-slate-100 px-0.5 rounded"><%= @home_abbr || '—' %></code>.</p>
<div class="grid md:grid-cols-2 gap-4 mb-8">
  <%= render 'game_team_season_card', label: 'Visitante', abbr: @away_abbr, stat: @team_stats_away, season: @season %>
  <%= render 'game_team_season_card', label: 'Casa', abbr: @home_abbr, stat: @team_stats_home, season: @season %>
</div>

<h2 class="text-lg font-semibold text-slate-800 mb-2">Elencos · temporada e box (quando existir)</h2>
<p class="text-xs text-slate-500 mb-3">Elenco por <code class="bg-slate-100 px-0.5 rounded">players.team</code> ou <code class="bg-slate-100 px-0.5 rounded">player_season_stats</code>. Cada coluna usa <strong>médias da temporada</strong> (cinza) até existir linha de <strong>box score</strong> deste jogo (preto) em <code class="bg-slate-100 px-0.5 rounded">player_game_stats</code> para este <code class="bg-slate-100 px-0.5 rounded">game_id</code>.</p>
<%= render 'game_roster_table', title: "Visitante — #{@game.away_team}", abbr: @away_abbr, roster: @away_roster, pgs_by_player_id: @pgs_by_player_id, pss_by_player_id: @pss_by_player_id, season: @season %>
<%= render 'game_roster_table', title: "Casa — #{@game.home_team}", abbr: @home_abbr, roster: @home_roster, pgs_by_player_id: @pgs_by_player_id, pss_by_player_id: @pss_by_player_id, season: @season %>

<div class="rounded-lg border border-violet-200 bg-violet-50/70 px-3 py-2 text-sm text-violet-950 mb-4 flex flex-wrap items-center justify-between gap-2">
  <span>Análises da IA deste jogo ficam na <strong>Central de IA</strong> (filtro por texto, ordenação).</span>
  <%= link_to 'Abrir Central de IA →', ai_hub_path(game_id: @game.id), class: 'font-semibold text-violet-800 hover:underline whitespace-nowrap' %>
</div>

<h2 class="text-lg font-semibold text-slate-800 mb-2">Jogadores · player props (pontos)</h2>
<p class="text-xs text-slate-500 mb-3">Métricas focadas em <strong>over de pontos</strong>: médias (temporada, L5, L10), frequência acima de faixas e da linha sugerida, tendência (L5 − temporada), volume (MIN / FGA / FTA) e score de confiança 0–100.</p>
<% if @players.empty? %>
  <p class="text-slate-500 mb-6">Nenhum jogador encontrado nos elencos dos times deste jogo (campo <code class="text-xs bg-slate-100 px-1 rounded">team</code> ou <code class="text-xs bg-slate-100 px-1 rounded">player_season_stats.team_abbr</code> alinhado às abreviações do placar). Sincronize elenco / temporada ou ajuste nomes dos times.</p>
<% else %>
  <div class="grid gap-4 mb-6">
    <% @players.each do |player| %>
      <% m = metrics_bundle_for_player(player, @game) %>
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm <%= player_scenario_rail_class(m[:confidence_hint]) %>">
        <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
          <div>
            <h3 class="text-lg font-semibold text-slate-900"><%= player.name %></h3>
            <p class="text-sm text-slate-500"><%= player.team %> · NBA ID: <%= player.nba_player_id || '—' %></p>
            <p class="text-xs text-slate-600 mt-2">
              <span class="font-semibold text-slate-800">Confiança (modelo): <%= m[:confidence_hint] %>/100</span>
              <span class="mx-2 text-slate-300">|</span>
              Linha ref.: <strong><%= m[:default_line] %></strong> pts
              <span class="mx-2 text-slate-300">|</span>
              Streak:
              <span class="inline-block ml-1 rounded px-2 py-0.5 text-xs font-medium <%= streak_badge_class(m[:streak]) %>"><%= m[:streak] %></span>
            </p>
          </div>
          <%= link_to 'Alertas / jogador', player_path(player), class: 'text-sm text-orange-700 hover:underline' %>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-2 text-sm">
          <div class="rounded bg-slate-50 p-2">
            <p class="text-slate-500 text-xs uppercase tracking-wide">Média temporada</p>
            <p class="font-semibold text-slate-900"><%= dash_num(m[:season_avg]) %> pts</p>
          </div>
          <div class="rounded bg-slate-50 p-2">
            <p class="text-slate-500 text-xs uppercase tracking-wide">Últimos 5</p>
            <p class="font-semibold text-slate-900"><%= dash_num(m[:last_5]) %> pts</p>
          </div>
          <div class="rounded bg-slate-50 p-2">
            <p class="text-slate-500 text-xs uppercase tracking-wide">Últimos 10</p>
            <p class="font-semibold text-slate-900"><%= dash_num(m[:last_10]) %> pts</p>
          </div>
          <div class="rounded bg-slate-50 p-2">
            <p class="text-slate-500 text-xs uppercase tracking-wide">Vs adversário</p>
            <p class="font-semibold text-slate-900"><%= dash_num(m[:vs_opponent]) %> pts</p>
          </div>
          <div class="rounded bg-slate-50 p-2">
            <p class="text-slate-500 text-xs uppercase tracking-wide">Desvio / variância</p>
            <p class="font-semibold text-slate-900"><%= dash_num(m[:std_dev]) %> / <%= dash_num(m[:variance]) %></p>
          </div>
          <div class="rounded bg-slate-50 p-2">
            <p class="text-slate-500 text-xs uppercase tracking-wide">Coef. variação</p>
            <p class="font-semibold text-slate-900"><%= dash_num(m[:cv]) %></p>
          </div>
          <div class="rounded bg-slate-50 p-2">
            <p class="text-slate-500 text-xs uppercase tracking-wide">% &gt;15 / &gt;20 / &gt;25</p>
            <p class="font-semibold text-slate-900"><%= dash_num(m[:over_15], '%') %> · <%= dash_num(m[:over_20], '%') %> · <%= dash_num(m[:over_25], '%') %></p>
          </div>
          <div class="rounded bg-slate-50 p-2">
            <p class="text-slate-500 text-xs uppercase tracking-wide">MIN méd · pts/min</p>
            <p class="font-semibold text-slate-900"><%= dash_num(m[:minutes_avg]) %> · <%= dash_num(m[:ppm]) %></p>
          </div>
          <div class="rounded bg-slate-50 p-2">
            <p class="text-slate-500 text-xs uppercase tracking-wide">FGA méd · FTA méd</p>
            <p class="font-semibold text-slate-900"><%= dash_num(m[:fga_avg]) %> · <%= dash_num(m[:fta_avg]) %></p>
          </div>
          <div class="rounded bg-slate-50 p-2">
            <p class="text-slate-500 text-xs uppercase tracking-wide">FGA+FTA méd (uso)</p>
            <p class="font-semibold text-slate-900"><%= dash_num(m[:usage]) %></p>
          </div>
          <div class="rounded bg-slate-50 p-2">
            <p class="text-slate-500 text-xs uppercase tracking-wide">Tendência (L5 − temp.)</p>
            <p class="font-semibold text-slate-900"><%= dash_num(m[:trend]) %></p>
          </div>
          <div class="rounded bg-slate-50 p-2">
            <p class="text-slate-500 text-xs uppercase tracking-wide">Tendência (L10 − temp.)</p>
            <p class="font-semibold text-slate-900"><%= dash_num(m[:trend_last_10]) %></p>
          </div>
          <div class="rounded bg-slate-50 p-2">
            <p class="text-slate-500 text-xs uppercase tracking-wide">% acima da linha</p>
            <p class="font-semibold text-slate-900"><%= dash_num(m[:over_line_rate], '%') %> <span class="text-xs font-normal text-slate-500">(linha <%= m[:default_line] %>)</span></p>
          </div>
          <div class="rounded bg-slate-50 p-2">
            <p class="text-slate-500 text-xs uppercase tracking-wide">Média casa</p>
            <p class="font-semibold text-slate-900"><%= dash_num(m[:home_avg]) %> pts</p>
          </div>
          <div class="rounded bg-slate-50 p-2">
            <p class="text-slate-500 text-xs uppercase tracking-wide">Média fora</p>
            <p class="font-semibold text-slate-900"><%= dash_num(m[:away_avg]) %> pts</p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<% if @my_bets.any? %>
  <div class="rounded-xl border border-indigo-200 bg-indigo-50/40 p-4 shadow-sm mb-6">
    <h2 class="text-lg font-semibold text-indigo-950 mb-1">Minhas apostas neste jogo</h2>
    <p class="text-xs text-indigo-900/80 mb-3">Props de <strong>pontos</strong>: informe os pontos reais do jogador; se forem <strong>maiores que a linha</strong>, a aposta vira <span class="text-emerald-700 font-medium">win</span>; caso contrário, <span class="text-red-700 font-medium">loss</span>.</p>
    <ul class="space-y-4">
      <% @my_bets.each do |bet| %>
        <li class="rounded-lg border border-indigo-100 bg-white p-3 text-sm">
          <div class="flex flex-wrap items-baseline justify-between gap-2 mb-2">
            <span class="font-semibold text-slate-900"><%= bet.player.name %></span>
            <span class="text-slate-600">
              <%= bet.bet_type %> · linha <strong><%= bet.line %></strong>
              <% if bet.odds.present? %> · odds <%= bet.odds %><% end %>
            </span>
          </div>
          <p class="text-xs text-slate-500 mb-2">
            Resultado: <strong class="text-slate-800"><%= bet.result %></strong>
            <% if bet.final_stat_value.present? %> · pontos registrados: <strong><%= bet.final_stat_value %></strong><% end %>
          </p>
          <% if bet.points_prop? %>
            <%= form_with model: bet, url: game_bet_path(@game, bet), method: :patch, local: true, class: 'flex flex-wrap items-end gap-2' do |f| %>
              <div>
                <%= f.label :final_stat_value, 'Pontos no jogo', class: 'block text-xs font-medium text-slate-600 mb-1' %>
                <%= f.number_field :final_stat_value, step: 'any', class: 'w-28 rounded border border-slate-300 px-2 py-1.5 text-sm tabular-nums' %>
              </div>
              <%= f.submit 'Salvar e resolver over', class: 'bg-indigo-700 hover:bg-indigo-600 text-white text-xs font-medium py-2 px-3 rounded cursor-pointer' %>
            <% end %>
          <% else %>
            <%= form_with model: bet, url: game_bet_path(@game, bet), method: :patch, local: true, class: 'flex flex-wrap items-end gap-2' do |f| %>
              <div>
                <%= f.label :result, 'Resultado manual', class: 'block text-xs font-medium text-slate-600 mb-1' %>
                <%= f.select :result, Bet::RESULTS.map { |r| [r, r] }, {}, class: 'rounded border border-slate-300 px-2 py-1.5 text-sm' %>
              </div>
              <%= f.submit 'Atualizar', class: 'bg-slate-700 hover:bg-slate-600 text-white text-xs font-medium py-2 px-3 rounded cursor-pointer' %>
            <% end %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>

<% if current_user.admin? && @players.any? %>
  <div class="rounded-lg border border-amber-200 bg-amber-50/50 px-3 py-2 text-sm text-amber-950 mb-6">
    Admin: rode novas análises na <%= link_to 'Central de IA', ai_hub_path(game_id: @game.id), class: 'font-semibold underline' %> (formulário completo + contexto manual).
  </div>
<% end %>

<div class="grid md:grid-cols-2 gap-4 mb-6">
  <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <h2 class="text-lg font-semibold text-slate-800 mb-2">Comentários</h2>
    <ul class="space-y-2 mb-4 max-h-64 overflow-y-auto">
      <% @comments.each do |c| %>
        <li class="text-sm border-b border-slate-100 pb-2">
          <span class="font-medium text-slate-700"><%= c.user.email %></span>
          <span class="text-slate-400 text-xs"><%= c.created_at.strftime('%d/%m %H:%M') %></span>
          <p class="text-slate-600 mt-1"><%= c.content %></p>
        </li>
      <% end %>
      <% if @comments.empty? %>
        <li class="text-slate-500 text-sm">Nenhum comentário ainda.</li>
      <% end %>
    </ul>
    <%= form_with model: Comment.new, url: game_comments_path(@game), local: true, class: 'space-y-2' do |f| %>
      <%= f.text_area :content, rows: 3, placeholder: 'Seu comentário…', class: 'w-full rounded border border-slate-300 px-3 py-2 text-sm' %>
      <%= f.submit 'Publicar', class: 'bg-slate-800 hover:bg-slate-700 text-white text-sm py-2 px-2 rounded' %>
    <% end %>
  </div>

  <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
    <h2 class="text-lg font-semibold text-slate-800 mb-2">Registrar aposta</h2>
    <% if @players.any? %>
      <%= form_with model: Bet.new, url: game_bets_path(@game), local: true, class: 'space-y-2' do |f| %>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Jogador</label>
          <%= f.select :player_id, @players.map { |p| ["#{p.name} (#{p.team})", p.id] }, {}, class: 'w-full rounded border border-slate-300 px-3 py-2 text-sm' %>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Tipo</label>
          <%= f.select :bet_type, [['Pontos', 'points'], ['Rebotes', 'rebounds']], {}, class: 'w-full rounded border border-slate-300 px-3 py-2 text-sm' %>
        </div>
        <div>
          <%= f.label :line, 'Linha', class: 'block text-sm font-medium text-slate-700 mb-1' %>
          <%= f.text_field :line, class: 'w-full rounded border border-slate-300 px-3 py-2 text-sm' %>
        </div>
        <div>
          <%= f.label :odds, 'Odds', class: 'block text-sm font-medium text-slate-700 mb-1' %>
          <%= f.text_field :odds, class: 'w-full rounded border border-slate-300 px-3 py-2 text-sm' %>
        </div>
        <%= f.submit 'Salvar aposta', class: 'bg-emerald-700 hover:bg-emerald-600 text-white text-sm py-2 px-2 rounded' %>
      <% end %>
    <% else %>
      <p class="text-slate-500 text-sm">É preciso haver jogadores nos elencos dos times (veja tabelas acima) para registrar aposta.</p>
    <% end %>
  </div>
</div>
