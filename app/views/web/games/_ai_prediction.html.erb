<% meta = (pred.analysis_meta || {}).stringify_keys %>
<div class="<%= ai_prediction_shell_class(pred) %>">
  <div class="flex flex-wrap items-start justify-between gap-3 mb-3">
    <p class="text-xs font-semibold text-slate-700">
      <%= pred.player.name %> · <%= pred.created_at.strftime('%d/%m %H:%M') %>
    </p>
    <div class="flex flex-wrap gap-2 text-xs">
      <span class="rounded-full px-3 py-1 font-medium bg-white/80 border border-slate-200">
        Confiança: <strong><%= pred.confidence_score.to_i %></strong>/100
      </span>
      <% if meta['probability_estimate'].present? %>
        <span class="rounded-full px-3 py-1 font-medium <%= ai_meta_pill_classes(:probability, meta['probability_estimate']) %>">
          Prob.: <%= meta['probability_estimate'] %>
        </span>
      <% end %>
      <% if meta['risk_level'].present? %>
        <span class="rounded-full px-3 py-1 font-medium <%= ai_meta_pill_classes(:risk, meta['risk_level']) %>">
          Risco: <%= meta['risk_level'] %>
        </span>
      <% end %>
      <% if meta['value_bet'].present? %>
        <span class="rounded-full px-3 py-1 font-medium <%= ai_meta_pill_classes(:value, meta['value_bet']) %>">
          Valor: <%= meta['value_bet'] %>
        </span>
      <% end %>
    </div>
  </div>
  <div class="text-sm text-slate-800 whitespace-pre-wrap leading-relaxed"><%= pred.output_text %></div>
</div>
