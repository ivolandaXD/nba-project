<div class="mb-6">
  <%= link_to '← Voltar', :back, class: 'text-sm text-orange-700 hover:underline' %>
</div>

<div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm mb-8">
  <h1 class="text-2xl font-bold text-slate-900"><%= @player.name %></h1>
  <p class="text-slate-600 mt-1"><%= @player.team %> · NBA ID <%= @player.nba_player_id || '—' %></p>
</div>

<div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm mb-8">
  <h2 class="text-lg font-semibold text-slate-800 mb-4">Meus alertas neste jogador</h2>
  <% if @my_alerts.any? %>
    <ul class="space-y-2 text-sm mb-6">
      <% @my_alerts.each do |a| %>
        <li class="flex flex-wrap justify-between gap-2 border-b border-slate-100 py-2">
          <span><span class="font-medium"><%= a.condition_type %></span> ≥ <%= a.threshold %></span>
          <span class="<%= a.is_active ? 'text-emerald-600' : 'text-slate-400' %>"><%= a.is_active ? 'ativo' : 'inativo' %></span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-slate-500 text-sm mb-6">Nenhum alerta ainda.</p>
  <% end %>

  <h3 class="text-md font-semibold text-slate-800 mb-3">Novo alerta</h3>
  <%= form_with model: Alert.new, url: player_alerts_path(@player), local: true, class: 'space-y-3 max-w-md' do |f| %>
    <div>
      <%= f.label :condition_type, 'Tipo', class: 'block text-sm font-medium text-slate-700 mb-1' %>
      <%= f.select :condition_type,
          Alert::CONDITION_TYPES.map { |t| [t.humanize, t] },
          {},
          class: 'w-full rounded border border-slate-300 px-3 py-2 text-sm' %>
    </div>
    <div>
      <%= f.label :threshold, 'Valor limite', class: 'block text-sm font-medium text-slate-700 mb-1' %>
      <%= f.text_field :threshold, class: 'w-full rounded border border-slate-300 px-3 py-2 text-sm', placeholder: 'ex: 25.5' %>
    </div>
    <%= f.submit 'Criar alerta', class: 'bg-orange-600 hover:bg-orange-700 text-white text-sm py-2 px-4 rounded' %>
  <% end %>
</div>
