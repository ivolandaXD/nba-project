<div class="rounded-lg border border-amber-100 bg-white/80 p-3 space-y-3">
  <p class="text-xs font-semibold text-amber-950 uppercase tracking-wide">Contexto de jogo (manual)</p>
  <p class="text-xs text-slate-600">Opcional. Refina probabilidade ajustada, EV e score final. Não automatizado.</p>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    <div class="sm:col-span-2">
      <label class="block text-xs font-medium text-slate-700 mb-1">Jogadores fora (elenco)</label>
      <textarea name="injuries_text" rows="2" placeholder="Um por linha ou separados por vírgula"
        class="w-full rounded border border-slate-300 px-3 py-2 text-sm"></textarea>
    </div>
    <div class="sm:col-span-2">
      <label class="block text-xs font-medium text-slate-700 mb-1">Jogadores retornando</label>
      <textarea name="returning_players_text" rows="2" placeholder="Um por linha ou separados por vírgula"
        class="w-full rounded border border-slate-300 px-3 py-2 text-sm"></textarea>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-700 mb-1">Ranking defensivo vs posição (1 = melhor defesa)</label>
      <input type="text" name="opponent_defense_rank_vs_position" placeholder="ex: 22"
        class="w-full rounded border border-slate-300 px-3 py-2 text-sm">
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-700 mb-1">Rebotes cedidos (rank, opcional)</label>
      <input type="text" name="opponent_rebounds_allowed_rank" placeholder="futuro"
        class="w-full rounded border border-slate-300 px-3 py-2 text-sm">
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-700 mb-1">Pace</label>
      <select name="pace" class="w-full rounded border border-slate-300 px-3 py-2 text-sm">
        <option value="">—</option>
        <option value="baixo">Baixo</option>
        <option value="medio">Médio</option>
        <option value="alto">Alto (+3% P(over) no modelo)</option>
      </select>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-700 mb-1">Casa / fora (jogador)</label>
      <select name="home_context" class="w-full rounded border border-slate-300 px-3 py-2 text-sm">
        <option value="">Automático (grade)</option>
        <option value="home">Casa</option>
        <option value="away">Fora</option>
      </select>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-700 mb-1">Spread (ex.: -12.5)</label>
      <input type="text" name="spread" placeholder="-12.5"
        class="w-full rounded border border-slate-300 px-3 py-2 text-sm tabular-nums">
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-700 mb-1">Desfalque chave no elenco (uso ofensivo)</label>
      <select name="key_teammate_out" class="w-full rounded border border-slate-300 px-3 py-2 text-sm">
        <option value="">Nenhum</option>
        <option value="moderate">Moderado (+5%)</option>
        <option value="strong">Forte (+10%)</option>
      </select>
    </div>
  </div>
  <div class="flex flex-wrap gap-4 items-center">
    <label class="inline-flex items-center gap-2 text-sm text-slate-800 cursor-pointer">
      <input type="checkbox" name="is_back_to_back" value="1" class="rounded border-slate-300">
      Back-to-back (−5%)
    </label>
    <label class="inline-flex items-center gap-2 text-sm text-slate-800 cursor-pointer">
      <input type="checkbox" name="matchup_favorable" value="1" class="rounded border-slate-300">
      Matchup favorável (+5%)
    </label>
  </div>
</div>
