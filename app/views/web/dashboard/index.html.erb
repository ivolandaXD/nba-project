<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
  <div>
    <h1 class="text-2xl font-bold text-slate-800">Jogos do dia</h1>
    <p class="text-slate-600 text-sm mt-1">
      <%= @scoreboard_date.strftime('%d/%m/%Y') %>
      <span class="text-slate-400">·</span>
      calendário NBA (Eastern Time)
    </p>
  </div>
  <%= button_to 'Atualizar jogos de hoje', dashboard_sync_games_path, method: :post, class: 'bg-slate-800 hover:bg-slate-700 text-white text-sm font-medium py-2 px-2 rounded shadow' %>
</div>

<% if @games.empty? %>
  <div class="rounded-xl border border-dashed border-slate-300 bg-white p-4 text-center text-slate-500">
    <p>Nenhum jogo cadastrado para hoje.</p>
    <p class="text-sm mt-2">Use <strong>Atualizar jogos de hoje</strong> para buscar a grade do dia acima (ET) na NBA.</p>
  </div>
<% else %>
  <div class="grid gap-2">
    <% @games.each do |game| %>
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
        <div>
          <p class="text-lg font-semibold text-slate-800">
            <span class="text-orange-700"><%= game.away_team %></span>
            <span class="text-slate-400 mx-2">@</span>
            <span class="text-slate-900"><%= game.home_team %></span>
          </p>
          <p class="text-sm text-slate-500 mt-1">
            <%= game.game_date&.strftime('%d/%m/%Y') %>
            <% if game.status.present? %>
              <span class="text-slate-400"> · </span>
              <span class="font-medium text-slate-600"><%= game.status %></span>
            <% end %>
          </p>
        </div>
        <%= link_to 'Ver detalhes', game_path(game), class: 'inline-flex justify-center bg-orange-600 hover:bg-orange-700 text-white text-sm font-medium py-2 px-2 rounded' %>
      </div>
    <% end %>
  </div>
<% end %>
