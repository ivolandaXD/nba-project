NBA_IMPORT_PLAYER_LIMIT=3
THE_ODDS_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_JSON_RESPONSE=true
CORS_ORIGINS=*
