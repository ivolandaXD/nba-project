# Database (override in production)
# DATABASE_URL=postgres://localhost/nba-project_development

# External APIs
NBA_SEASON=2024-25
# Importar game logs no máximo N jogadores por clique (teste em pequena escala)
NBA_IMPORT_PLAYER_LIMIT=3
THE_ODDS_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# true = resposta JSON estruturada (recomendado; exige modelo compatível com json_object)
OPENAI_JSON_RESPONSE=true

# CORS (comma-separated origins, or * for dev)
CORS_ORIGINS=*

# Seed admin (optional)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123
